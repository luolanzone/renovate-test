{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":gitSignOff",
  ],

  enabledManagers: ["gomod"],

  // Active release branches
  baseBranches: ["main", "release-1.1", "release-1.0"],
  prConcurrentLimit: 9,
  prHourlyLimit: 0,

  postUpdateOptions: ["gomodTidy"],

  separateMajorMinor: false,
  separateMinorPatch: false,

  labels: ["dependencies"],

  // GitHub Dependabot alerts → Renovate security PRs. Defaults (groupName: null, per-dep
  // branchTopic) are merged with force over top-level packageRules, so AWS grouping must live
  // here—not under root packageRules—or you get one PR per module (see renovatebot/renovate#15107).
  vulnerabilityAlerts: {
    enabled: true,
    packageRules: [
      {
        // matchBaseBranches here requires vulnerabilityAlerts.baseBranchPatterns; root
        // baseBranches already limits scanned bases.
        matchManagers: ["gomod"],
        matchPackagePrefixes: ["github.com/aws/"],
        enabled: true,
        groupName: "AWS SDK for Go dependencies",
        groupSlug: "aws-sdk-go",
      },
    ],
  },

  packageRules: [
    // Disable all regular updates for active release branches
    // Don't write any rules before this rule
    {
      matchBaseBranches: ["release-1.1", "release-1.0"],
      groupName: "all dependencies active release branches",
      groupSlug: "all-deps-active-release-branches",
      enabled: false,
    },

    // Re-enable AWS GitHub vulnerability remediations on release branches only (see blanket rule
    // above). groupName for those PRs is set under vulnerabilityAlerts.packageRules, not here.
    {
      matchManagers: ["gomod"],
      matchPackagePrefixes: ["github.com/aws/"],
      matchBaseBranches: ["release-1.1", "release-1.0"],
      matchJsonata: ["$exists(vulnerabilityFixVersion)"],
      enabled: true,
    },

    // Disable indirect go dependencies updates
    {
      matchManagers: ["gomod"],
      matchDepTypes: ["indirect"],
      enabled: false,
    },

    // Re-enable vulnerability/security updates for indirect go dependencies on all branches
    // Must come after both the release branch disable rule and the indirect disable rule
    {
      matchManagers: ["gomod"],
      matchDepTypes: ["indirect"],
      isVulnerabilityAlert: true,
      enabled: true,
    },
  ],
}
